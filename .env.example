# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# NOTION_API_KEY: Integration token for Notion
NOTION_API_KEY=""

# NOTION_GOALS_DB_ID: ID of the Goals database
NOTION_GOALS_DB_ID=""

# NOTION_PROJECTS_DB_ID: ID of the Projects database
NOTION_PROJECTS_DB_ID=""

# NOTION_TASKS_DB_ID: ID of the Tasks database
NOTION_TASKS_DB_ID=""

# NOTION_AGENTS_DB_ID: ID of the Agents database
NOTION_AGENTS_DB_ID=""
