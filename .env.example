# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# NOTION_CLIENT_ID: Notion OAuth Client ID
NOTION_CLIENT_ID=""

# NOTION_CLIENT_SECRET: Notion OAuth Client Secret
NOTION_CLIENT_SECRET=""

# NOTION_REDIRECT_URI: Notion OAuth Redirect URI (e.g., https://your-app.run.app/auth/notion/callback)
NOTION_REDIRECT_URI=""

# NOTION_GOALS_DB_ID: ID of the Goals database
NOTION_GOALS_DB_ID=""

# NOTION_PROJECTS_DB_ID: ID of the Projects database
NOTION_PROJECTS_DB_ID=""

# NOTION_TASKS_DB_ID: ID of the Tasks database
NOTION_TASKS_DB_ID=""

# NOTION_AGENTS_DB_ID: ID of the Agents database
NOTION_AGENTS_DB_ID=""
